# API base URL (include /api/v1 if your backend uses that prefix)
# Must include /api/v1 — paths in code are e.g. /auth/google
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Same Google OAuth client ID as GOOGLE_CLIENT_ID in backend .env
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
